{
  "manifest_version": "0.3",
  "name": "cal-com-pp-mcp",
  "display_name": "Cal.com",
  "version": "3.9.0",
  "description": "Cal.com API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/cal-com-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/cal-com-pp-mcp",
      "args": [],
      "env": {
        "CAL_COM_TOKEN": "${user_config.cal_com_token}"
      }
    }
  },
  "user_config": {
    "cal_com_token": {
      "type": "string",
      "title": "Cal.com API Key",
      "description": "Cal.com bearer token (cal_live_* or cal_test_*); managed-user access tokens and OAuth access tokens also accepted",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
