{
  "api_name": "wikipedia",
  "base_url": "https://en.wikipedia.org/api/rest_v1",
  "description": "Wikipedia REST API. Get article summaries, search, browse related topics,\nand access on-this-day events. No authentication required.\nUses a polite User-Agent header.",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "none"
  },
  "required_headers": [],
  "tools": [
    {
      "name": "feed_get-on-this-day",
      "description": "Events on this day",
      "method": "GET",
      "path": "/feed/onthisday/{type}/{month}/{day}",
      "no_auth": true,
      "params": [
        {
          "name": "type",
          "type": "string",
          "location": "query",
          "description": "Type"
        },
        {
          "name": "month",
          "type": "int",
          "location": "query",
          "description": "Month",
          "required": true
        },
        {
          "name": "day",
          "type": "int",
          "location": "path",
          "description": "Day",
          "required": true
        }
      ]
    },
    {
      "name": "page_get-html",
      "description": "Get article HTML",
      "method": "GET",
      "path": "/page/html/{title}",
      "no_auth": true,
      "params": [
        {
          "name": "title",
          "type": "string",
          "location": "path",
          "description": "Title",
          "required": true
        }
      ]
    },
    {
      "name": "page_get-media",
      "description": "Get article media",
      "method": "GET",
      "path": "/page/media-list/{title}",
      "no_auth": true,
      "params": [
        {
          "name": "title",
          "type": "string",
          "location": "path",
          "description": "Title",
          "required": true
        }
      ]
    },
    {
      "name": "page_get-random",
      "description": "Get a random article summary",
      "method": "GET",
      "path": "/page/random/summary",
      "no_auth": true,
      "params": []
    },
    {
      "name": "page_get-related",
      "description": "Get related articles",
      "method": "GET",
      "path": "/page/related/{title}",
      "no_auth": true,
      "params": [
        {
          "name": "title",
          "type": "string",
          "location": "path",
          "description": "Title",
          "required": true
        }
      ]
    },
    {
      "name": "page_get-summary",
      "description": "Get article summary",
      "method": "GET",
      "path": "/page/summary/{title}",
      "no_auth": true,
      "params": [
        {
          "name": "title",
          "type": "string",
          "location": "path",
          "description": "Article title (underscores for spaces, e.g. \"Python_(programming_language)\")",
          "required": true
        },
        {
          "name": "redirect",
          "type": "bool",
          "location": "query",
          "description": "Follow redirects"
        }
      ]
    }
  ]
}
