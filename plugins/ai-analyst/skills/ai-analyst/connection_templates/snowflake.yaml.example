# Connection Template: Snowflake
# Copy to .knowledge/datasets/{name}/manifest.yaml and fill in values.
# Requires: pip install snowflake-connector-python
# Auth: user/password or use key-pair authentication.

dataset_id: "{dataset_id}"
display_name: "{Display Name}"
description: "{Brief description of the dataset}"
domain: "{e-commerce|saas|fintech|marketplace|other}"
created_at: "{YYYY-MM-DD}"
is_seed: false

connection:
  type: snowflake
  account: "{account_identifier}"   # e.g., xy12345.us-east-1
  warehouse: "{warehouse}"
  database: "{database}"
  schema: "public"
  user: "{username}"
  password: "{password}"   # Consider using env vars: $SNOWFLAKE_PASSWORD

summary:
  table_count: null
  total_rows: null
  date_range: null
  primary_entities: []
  key_dimensions: []
  last_profiled: null

local_data:
  path: null
  duckdb: null

status: active
last_used: null
analysis_count: 0
