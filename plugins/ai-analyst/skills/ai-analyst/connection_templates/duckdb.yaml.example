# Connection Template: DuckDB / MotherDuck
# Copy to .knowledge/datasets/{name}/manifest.yaml and fill in values.

dataset_id: "{dataset_id}"
display_name: "{Display Name}"
description: "{Brief description of the dataset}"
domain: "{e-commerce|saas|fintech|marketplace|other}"
created_at: "{YYYY-MM-DD}"
is_seed: false

connection:
  type: duckdb           # or "motherduck" for cloud DuckDB
  database: "{database}"
  schema: "{schema}"     # SQL schema prefix for queries

summary:
  table_count: null      # Auto-populated by data profiler
  total_rows: null
  date_range: null
  primary_entities: []
  key_dimensions: []
  last_profiled: null

local_data:
  path: "data/{dataset_id}/"
  duckdb: "data/{dataset_id}/{database}.duckdb"

status: active
last_used: null
analysis_count: 0
