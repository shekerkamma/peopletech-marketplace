# Connection Template: PostgreSQL
# Copy to .knowledge/datasets/{name}/manifest.yaml and fill in values.

dataset_id: "{dataset_id}"
display_name: "{Display Name}"
description: "{Brief description of the dataset}"
domain: "{e-commerce|saas|fintech|marketplace|other}"
created_at: "{YYYY-MM-DD}"
is_seed: false

connection:
  type: postgres
  host: "localhost"
  port: 5432
  database: "{database}"
  schema: "public"
  user: "{username}"
  password: "{password}"   # Consider using env vars: $PG_PASSWORD

summary:
  table_count: null
  total_rows: null
  date_range: null
  primary_entities: []
  key_dimensions: []
  last_profiled: null

local_data:
  path: null               # No local fallback for Postgres by default
  duckdb: null

status: active
last_used: null
analysis_count: 0
